@page "/projects/edit/{Id:int}"
@attribute [Authorize(Roles = "Admin, Manager")]
@rendermode InteractiveServer

<AlertTitle TitleText="@($"Editing Project {Id}")"/>


<RadzenTemplateForm Data="@_projects" TItem="Projects" Submit="UpdateProject">
    <RadzenFieldset Text="Project Details">
        <div class="form-group mb-4">
            <RadzenLabel Text="Name"/>
            <RadzenTextBox @bind-Value="@_projects.Name"
                           data-testid="project_name"
                           class="input-style"
                           Name="name"/>
            <RadzenRequiredValidator Component="name" Text="Name is required"/>
        </div>

        <div class="form-group mb-4">
            <RadzenLabel Text="Description"/>
            <RadzenTextBox @bind-Value="@_projects.Description"
                           data-testid="project_description"
                           class="input-style"
                           Name="Description"/>
            <RadzenRequiredValidator Component="Description" Text="Description is required"/>
        </div>

        <div class="form-group mb-4">
            <RadzenLabel Text="Jira Project ID"/>
            <RadzenTextBox @bind-Value="@_projects.JiraProjectId"
                           class="input-style"
                           Name="JiraProjectId"/>
        </div>

        <div class="form-group mb-4">
            <RadzenLabel Text="Jira Integration"/>
            <RadzenDropDown @bind-Value="@_projects.JiraIntegrationId"
                            Data="@_integrations"
                            TextProperty="UniqueKey"
                            ValueProperty="Id"
                            class="input-style"
                            AllowClear="true"
                            Placeholder="Select Integration"
                            Name="JiraIntegrationId"/>
        </div>
    </RadzenFieldset>

    <CreateEditActions EntityName="projects" CreateEdit="Update"/>
</RadzenTemplateForm>

@code
{
    [Parameter] public int Id { get; set; }


    Projects _projects = new();
    List<Integrations> _integrations = [];

    protected override async Task OnInitializedAsync()
    {
        _projects = await ProjectModel.GetProjectById(Id);
        _integrations = await IntegrationsModel.GetListIntegrations();
    }

    private async Task UpdateProject()
    {
        var updated = await ProjectModel.UpdateProject(_projects);
        NavigationManager.NavigateTo("/");
        StateHasChanged();
        await FormNotificationService.NotifySuccess("Project Updated Successfully");
    }
}